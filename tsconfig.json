{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/(public)/HomePage/InsightsSection.tsx",
    "app/(public)/HomePage/CTASection.tsx",
    "app/(public)/HomePage/HeroSection.tsx",
    "app/(public)/HomePage/KnowUs.tsx",
    "app/(public)/contactus/page.tsx",
    "app/(public)/layout/Navbar.tsx",
    "app/(public)/layout/Footer.tsx",
    "app/(public)/HomePage/WhyUs.tsx",
    "app/(public)/HomePage/TransparencySection.tsx",
    "app/(public)/HomePage/SignatureApproach.tsx",
    "app/(public)/HomePage/ServicesGrid.tsx",
    "app/(public)/aboutus/page.tsx",
    "app/(public)/aboutus/OurFoundation.tsx",
    "app/(public)/aboutus/Banner.tsx",
    "app/(public)/contactus/Banner.tsx",
    "app/(public)/contactus/MapSection.tsx",
    "app/(public)/layout.tsx",
    "app/(public)/page.tsx",
    "app/(public)/aboutus/WeAreThe.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}